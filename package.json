{
    "name": "life",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && node ./src/build/cleanDist.js && vite build && node ./src/build/buildTime.js",
        "build:mom": "tsc && node ./src/build/cleanDist.js && node ./src/build/buildForMom.js && vite build && node ./src/build/buildTime.js",
        "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "lint:ts": "tsc --noEmit -p tsconfig.json --composite false",
        "preview": "vite preview",
        "prepare": "husky install"
    },
    "lint-staged": {
        "*.{js,jsx,cjs,mjs,ts,tsx,cts,mts}": "eslint",
        "*.{css,scss,sass,js,ts,jsx,tsx}": "prettier --check --ignore-unknown",
        "*.{ts,tsx}": "bash -c 'npm run lint:ts'"
    },
    "dependencies": {
        "@emotion/react": "^11.11.1",
        "@emotion/styled": "^11.11.0",
        "@mui/icons-material": "^5.11.16",
        "@mui/material": "^5.13.6",
        "@reduxjs/toolkit": "^1.9.5",
        "js-cookie": "^3.0.5",
        "notistack": "^3.0.1",
        "react": "^18.2.0",
        "react-datepicker": "^4.14.1",
        "react-dom": "^18.2.0",
        "react-quill": "^2.0.0",
        "react-redux": "^8.1.1",
        "react-router-dom": "^6.14.0",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@commitlint/config-conventional": "^17.6.6",
        "@types/js-cookie": "^3.0.3",
        "@types/node": "^20.3.1",
        "@types/react": "^18.0.37",
        "@types/react-datepicker": "^4.11.2",
        "@types/react-dom": "^18.0.11",
        "@typescript-eslint/eslint-plugin": "^5.59.0",
        "@typescript-eslint/parser": "^5.59.0",
        "@vitejs/plugin-react-swc": "^3.0.0",
        "autoprefixer": "^10.4.14",
        "commitlint": "^17.6.6",
        "eslint": "^8.38.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.3.4",
        "husky": "^8.0.3",
        "lint-staged": "^13.2.2",
        "postcss": "^8.4.24",
        "prettier": "2.8.8",
        "prettier-plugin-tailwindcss": "^0.3.0",
        "sass": "^1.63.6",
        "tailwindcss": "^3.3.2",
        "typescript": "^5.0.2",
        "vite": "^4.3.9"
    }
}
